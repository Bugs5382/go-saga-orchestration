{
  "id": "wf_map",
  "version": 1,
  "name": "double each element",
  "start": "s1",
  "steps": [
    { "id": "s1", "type": "set_var", "inputs": {"out_var":"xs","value":[1,2,3]}, "next": "s2" },
    { "id": "s2", "type": "map", "inputs": {"list":"xs","expr":"_ * 2.0","out_var":"doubled"}, "next": "end" },
    { "id": "end", "type": "end" }
  ],
  "published": true
}
