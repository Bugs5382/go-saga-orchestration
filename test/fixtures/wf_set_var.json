{
  "id": "wf_set_var",
  "version": 1,
  "name": "Two set_var steps then end",
  "start": "s1",
  "steps": [
    { "id": "s1", "type": "set_var", "inputs": {"out_var":"x","value":42}, "next": "s2" },
    { "id": "s2", "type": "set_var", "inputs": {"out_var":"y","expr":"x * 2.0"}, "next": "end" },
    { "id": "end", "type": "end" }
  ],
  "published": true
}
