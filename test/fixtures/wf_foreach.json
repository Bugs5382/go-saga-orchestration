{
  "id": "wf_foreach",
  "version": 1,
  "name": "foreach demo",
  "start": "seed",
  "steps": [
    {
      "id": "seed",
      "type": "set_var",
      "inputs": { "out_var": "xs", "value": [1, 2, 3] },
      "next": "fe"
    },
    {
      "id": "fe",
