{
  "id": "wf_demo_branching",
  "version": 1,
  "name": "Demo: data -> branch on rule -> end",
  "start": "s1",
  "steps": [
    { "id": "s1", "type": "set_var",  "inputs": {"out_var":"x","value":42}, "next": "s2" },
    { "id": "s2", "type": "transform","inputs": {"expr":"x * 2.0","out_var":"y"}, "next": "s3" },
    { "id": "s3", "type": "merge",    "inputs": {"from":"{'meta':{'src':'demo'}}","into":"ctx"}, "next": "s4" },
    { "id": "s4", "type": "filter",   "inputs": {"list":"[1,2,3,4]","expr":"_ > 2","out_var":"tail"}, "next": "s5" },
    { "id": "s5", "type": "log",      "inputs": {"message":"branching ahead","level":"info"}, "next": "s6" },
    { "id": "s6", "type": "decision", "inputs": {"rule_id":"demo_branch"},
      "branches": { "high": {"next":"sH"}, "low": {"next":"sL"} } },
    { "id": "sH", "type": "set_var",  "inputs": {"out_var":"branch_taken","value":"high"}, "next": "end" },
    { "id": "sL", "type": "set_var",  "inputs": {"out_var":"branch_taken","value":"low"},  "next": "end" },
    { "id": "end", "type": "end" }
  ],
  "published": true
}
