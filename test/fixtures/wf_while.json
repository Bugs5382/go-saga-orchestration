{
  "id": "wf_while",
  "version": 1,
  "name": "while demo — counts to 3",
  "start": "init",
  "steps": [
    { "id": "init", "type": "set_var",  "inputs": {"out_var": "counter", "value": 0},        "next": "w" },
    { "id": "w",    "type": "while",    "inputs": {"condition": "counter < 3.0", "max_iterations": 10},
      "branches": {"continue": {"next": "incr"}, "exit": {"next": "end"}} },
    { "id": "incr", "type": "transform","inputs": {"expr": "counter + 1.0", "out_var": "counter"}, "next": "w" },
    { "id": "end",  "type": "end" }
  ],
  "published": true
}
