{
  "id": "wf_filter",
  "version": 1,
  "name": "filter a seeded list",
  "start": "s1",
  "steps": [
    { "id": "s1", "type": "set_var", "inputs": {"out_var":"xs","value":[1,2,3,4,5]}, "next": "s2" },
    { "id": "s2", "type": "filter", "inputs": {"list":"xs","expr":"_ > 2.0","out_var":"tail"}, "next": "end" },
    { "id": "end", "type": "end" }
  ],
  "published": true
}
